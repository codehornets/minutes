{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://useminutes.app/schemas/skill-pack.schema.json",
  "title": "Minutes Skill Pack",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "title",
    "description",
    "skill_names"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "recommended_surface": {
      "type": "string",
      "enum": ["claude-code-plugin"]
    },
    "skill_names": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "uniqueItems": true
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trigger", "skill_name"],
        "properties": {
          "trigger": {
            "type": "string",
            "minLength": 3,
            "maxLength": 160
          },
          "skill_name": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "additionalProperties": false
      }
    },
    "recommended_for": {
      "type": "object",
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        },
        "contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 200
      }
    }
  },
  "additionalProperties": false
}
